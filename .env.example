# KURO — variables de entorno. Copiar a `.env.local` y completar.
# `.env.local` está gitignored (NUNCA commitear valores reales).

# ── Backend API ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/

# ── Sentry (telemetría de crashes) ───────────────────────────
# DSN público del proyecto Sentry. Sin esto, el SDK queda deshabilitado
# (no rompe nada: la app corre igual, solo no reporta).
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn-here
# Opcional: override del environment reportado (default: NODE_ENV).
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Solo para CI/CD — upload de source maps en el build.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
